# ============================================
# Smart Energy Monitor - Environment Variables
# ============================================

# ---- FRONTEND (Vanilla JS) ----
# The frontend no longer uses environment variables at build time.
# Instead, edit js/supabase.js directly and set:
#   supabaseUrl = 'https://your-project-id.supabase.co'
#   supabaseAnonKey = 'your-anon-public-key-here'

# ---- SERVER-SIDE (Vercel Serverless Functions) ----
# These environment variables are used by the API endpoint (api/sensor-data.js).
# Set them in Vercel Dashboard → Settings → Environment Variables.

# Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (public, read-only)
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Supabase Service Role Key (server-side only, full database access)
# Get this from: Supabase Dashboard → Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
